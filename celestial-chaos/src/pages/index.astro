<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Zest Wellness Station | Parceria para Academias</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600;1,700&family=DM+Sans:ital,opsz,wght@0,9..40,200..900;1,9..40,200..900&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --cream: #f6f1e7;
        --cream-dark: #ede7d7;
        --green: #7a9a6e;
        --green-dark: #4d7140;
        --green-deep: #2d4a26;
        --peach: #d4845a;
        --peach-light: #e8a882;
        --text: #2c2c2c;
        --text-muted: #7a7068;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        font-family: "DM Sans", sans-serif;
        background-color: var(--cream);
        color: var(--text);
        overflow-x: hidden;
      }

      .serif {
        font-family: "Cormorant Garamond", serif;
      }

      /* ── Noise texture overlay ── */
      body::before {
        content: "";
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 512 512' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
        opacity: 0.4;
      }

      /* ── Navigation ── */
      nav {
        position: fixed;
        width: 100%;
        z-index: 1000;
        padding: 1.5rem 2rem;
        transition: all 0.5s cubic-bezier(0.23, 1, 0.32, 1);
      }
      nav.scrolled {
        padding: 0.75rem 2rem;
        background: rgba(246, 241, 231, 0.92);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(122, 154, 110, 0.15);
        box-shadow: 0 8px 40px rgba(45, 74, 38, 0.06);
      }
      .nav-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      .nav-logo {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .nav-logo-icon {
        width: 38px;
        height: 38px;
        background: var(--green-deep);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .nav-links {
        display: flex;
        gap: 2.5rem;
        align-items: center;
        list-style: none;
      }
      .nav-links a {
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-deep);
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .nav-links a:hover {
        opacity: 0.5;
      }
      .btn-nav {
        background: var(--peach);
        color: white !important;
        padding: 0.6rem 1.5rem;
        border-radius: 100px;
        font-size: 0.65rem !important;
        letter-spacing: 0.2em !important;
        transition: all 0.3s ease !important;
        box-shadow: 0 4px 20px rgba(212, 132, 90, 0.3);
      }
      .btn-nav:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 30px rgba(212, 132, 90, 0.4) !important;
        opacity: 1 !important;
      }

      /* ── Reveal animations ── */
      .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition:
          opacity 0.9s cubic-bezier(0.23, 1, 0.32, 1),
          transform 0.9s cubic-bezier(0.23, 1, 0.32, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      .reveal-delay-1 {
        transition-delay: 0.1s;
      }
      .reveal-delay-2 {
        transition-delay: 0.2s;
      }
      .reveal-delay-3 {
        transition-delay: 0.3s;
      }
      .reveal-delay-4 {
        transition-delay: 0.4s;
      }
      .reveal-delay-5 {
        transition-delay: 0.5s;
      }

      /* ── Hero ── */
      .hero {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
        align-items: center;
        gap: 4rem;
        padding: 8rem 2rem 4rem;
        max-width: 1400px;
        margin: 0 auto;
      }
      @media (max-width: 1024px) {
        .hero {
          grid-template-columns: 1fr;
          padding: 7rem 1.5rem 4rem;
        }
        .hero-visual {
          display: none;
        }
      }
      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.35rem 1rem 0.35rem 0.5rem;
        background: rgba(122, 154, 110, 0.12);
        border: 1px solid rgba(122, 154, 110, 0.25);
        border-radius: 100px;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-dark);
        margin-bottom: 1.5rem;
      }
      .eyebrow-dot {
        width: 6px;
        height: 6px;
        background: var(--green);
        border-radius: 50%;
        animation: pulse-dot 2s infinite;
      }
      @keyframes pulse-dot {
        0%,
        100% {
          opacity: 1;
          transform: scale(1);
        }
        50% {
          opacity: 0.5;
          transform: scale(0.7);
        }
      }
      .hero-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(3rem, 5vw, 5.5rem);
        font-weight: 600;
        line-height: 1;
        letter-spacing: -0.02em;
        color: var(--green-deep);
        margin-bottom: 1.5rem;
      }
      .hero-title em {
        font-style: italic;
        color: var(--peach);
      }
      .hero-sub {
        font-size: 1.1rem;
        color: var(--text-muted);
        line-height: 1.75;
        max-width: 500px;
        margin-bottom: 2.5rem;
      }
      .hero-ctas {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
      }
      .btn-primary {
        background: var(--green-deep);
        color: white;
        padding: 1rem 2.5rem;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        transition: all 0.35s cubic-bezier(0.23, 1, 0.32, 1);
        box-shadow: 0 6px 30px rgba(45, 74, 38, 0.25);
      }
      .btn-primary:hover {
        transform: translateY(-3px);
        box-shadow: 0 12px 40px rgba(45, 74, 38, 0.35);
      }
      .btn-ghost {
        color: var(--green-deep);
        padding: 1rem 2rem;
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        text-decoration: none;
        border: 1.5px solid rgba(45, 74, 38, 0.25);
        transition: all 0.3s ease;
      }
      .btn-ghost:hover {
        border-color: var(--green-deep);
        background: rgba(45, 74, 38, 0.04);
      }

      /* ── Hero stats bar ── */
      .hero-stats {
        display: flex;
        gap: 2rem;
        margin-top: 3rem;
        padding-top: 2.5rem;
        border-top: 1px solid rgba(45, 74, 38, 0.12);
      }
      .hero-stat-num {
        font-family: "Cormorant Garamond", serif;
        font-size: 2.5rem;
        font-weight: 700;
        color: var(--green-deep);
        line-height: 1;
      }
      .hero-stat-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-top: 4px;
      }

      /* ── Hero visual ── */
      .hero-visual {
        position: relative;
        display: flex;
        justify-content: flex-end;
      }
      .hero-image-wrap {
        position: relative;
        width: 90%;
      }
      .hero-img {
        width: 100%;
        aspect-ratio: 4/5;
        border-radius: 2.5rem;
        background: var(--cream-dark);
        background-image: url("/assets/mercado.png");
        background-size: cover;
        background-position: left center;
        box-shadow: 0 60px 120px -20px rgba(45, 74, 38, 0.2);
        overflow: hidden;
        position: relative;
      }
      .hero-img::after {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          to top,
          rgba(45, 74, 38, 0.5) 0%,
          transparent 60%
        );
        border-radius: inherit;
      }
      .hero-badge {
        position: absolute;
        bottom: 2rem;
        left: 2rem;
        right: 2rem;
        background: rgba(246, 241, 231, 0.95);
        backdrop-filter: blur(20px);
        border-radius: 1.5rem;
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1rem;
        z-index: 2;
        box-shadow: 0 8px 40px rgba(0, 0, 0, 0.15);
      }
      .hero-badge-icon {
        width: 44px;
        height: 44px;
        background: var(--green);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
      }
      .hero-badge-title {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--green-deep);
      }
      .hero-badge-sub {
        font-size: 0.65rem;
        color: var(--text-muted);
        margin-top: 2px;
      }
      .hero-tag {
        position: absolute;
        top: 2rem;
        right: -1.5rem;
        background: var(--peach);
        color: white;
        padding: 0.8rem 1.2rem;
        border-radius: 1.25rem;
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        box-shadow: 0 8px 30px rgba(212, 132, 90, 0.35);
        writing-mode: horizontal-tb;
      }
      /* Floating dots */
      .float-dot {
        position: absolute;
        border-radius: 50%;
        animation: float-anim 6s ease-in-out infinite;
      }
      @keyframes float-anim {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-15px);
        }
      }

      /* ── Section shared ── */
      .section-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 1rem;
      }
      .section-title {
        font-family: "Cormorant Garamond", serif;
        font-size: clamp(2.2rem, 4vw, 3.5rem);
        font-weight: 600;
        line-height: 1.1;
        color: var(--green-deep);
      }
      .section-title em {
        font-style: italic;
        color: var(--peach);
      }

      /* ── Problem section ── */
      .problem-section {
        padding: 8rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
      }
      .problem-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: end;
        margin-bottom: 4rem;
      }
      @media (max-width: 768px) {
        .problem-header {
          grid-template-columns: 1fr;
        }
      }
      .problem-quote {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.4rem;
        font-style: italic;
        color: var(--text-muted);
        line-height: 1.6;
        padding-left: 1.5rem;
        border-left: 3px solid var(--peach);
      }
      .problem-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
      }
      @media (max-width: 900px) {
        .problem-cards {
          grid-template-columns: 1fr;
        }
      }
      .problem-card {
        background: white;
        border-radius: 2rem;
        padding: 2.5rem;
        border: 1px solid rgba(122, 154, 110, 0.12);
        transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
        cursor: default;
        position: relative;
        overflow: hidden;
      }
      .problem-card::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
          135deg,
          rgba(122, 154, 110, 0.04),
          transparent
        );
        opacity: 0;
        transition: opacity 0.4s;
      }
      .problem-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 30px 60px rgba(45, 74, 38, 0.1);
      }
      .problem-card:hover::before {
        opacity: 1;
      }
      .problem-card-number {
        font-family: "Cormorant Garamond", serif;
        font-size: 5rem;
        font-weight: 300;
        color: rgba(122, 154, 110, 0.15);
        line-height: 1;
        margin-bottom: 1rem;
      }
      .problem-card-icon {
        width: 48px;
        height: 48px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.5rem;
      }
      .problem-card h3 {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: var(--green-deep);
        margin-bottom: 0.75rem;
      }
      .problem-card p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.75;
      }

      /* ── Metrics band ── */
      .metrics-band {
        background: var(--green-deep);
        padding: 4rem 2rem;
        position: relative;
        overflow: hidden;
      }
      .metrics-band::before {
        content: "";
        position: absolute;
        top: -50%;
        right: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(
          circle,
          rgba(122, 154, 110, 0.15),
          transparent 70%
        );
        pointer-events: none;
      }
      .metrics-inner {
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 2rem;
        text-align: center;
      }
      @media (max-width: 768px) {
        .metrics-inner {
          grid-template-columns: repeat(2, 1fr);
        }
      }
      .metric-num {
        font-family: "Cormorant Garamond", serif;
        font-size: 3.5rem;
        font-weight: 700;
        color: white;
        line-height: 1;
        margin-bottom: 0.5rem;
      }
      .metric-label {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.5);
      }
      .metric-divider {
        width: 30px;
        height: 2px;
        background: var(--peach);
        margin: 0.75rem auto;
      }

      /* ── Solution section ── */
      .solution-section {
        padding: 8rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: center;
      }
      @media (max-width: 1024px) {
        .solution-section {
          grid-template-columns: 1fr;
        }
      }
      .solution-steps {
        display: flex;
        flex-direction: column;
        gap: 0;
      }
      .solution-step {
        display: flex;
        gap: 2rem;
        padding: 2rem 0;
        border-bottom: 1px solid rgba(45, 74, 38, 0.08);
        transition: all 0.3s ease;
        cursor: default;
      }
      .solution-step:first-child {
        padding-top: 0;
      }
      .solution-step:last-child {
        border-bottom: none;
      }
      .solution-step:hover .step-num {
        background: var(--green-deep);
        color: white;
      }
      .step-num {
        flex-shrink: 0;
        width: 52px;
        height: 52px;
        border: 2px solid rgba(45, 74, 38, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: "Cormorant Garamond", serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--green-deep);
        transition: all 0.3s ease;
      }
      .step-title {
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green);
        margin-bottom: 0.5rem;
      }
      .step-body {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.75;
      }

      .solution-right {
      }
      .solution-pullquote {
        background: white;
        border: 1px solid rgba(122, 154, 110, 0.15);
        border-radius: 2rem;
        padding: 2.5rem;
        margin-top: 2.5rem;
        position: relative;
      }
      .pullquote-mark {
        font-family: "Cormorant Garamond", serif;
        font-size: 6rem;
        color: rgba(212, 132, 90, 0.2);
        line-height: 0.5;
        display: block;
        margin-bottom: 1rem;
      }
      .pullquote-text {
        font-family: "Cormorant Garamond", serif;
        font-size: 1.3rem;
        font-style: italic;
        color: var(--green-deep);
        line-height: 1.6;
      }

      /* ── Comparison section ── */
      .comparison-section {
        padding: 8rem 2rem;
        background: linear-gradient(135deg, var(--green-deep) 0%, #1a3314 100%);
        position: relative;
        overflow: hidden;
      }
      .comparison-section::before {
        content: "";
        position: absolute;
        bottom: 0;
        left: -10%;
        width: 70%;
        height: 70%;
        background: radial-gradient(
          ellipse,
          rgba(212, 132, 90, 0.08),
          transparent 70%
        );
        pointer-events: none;
      }
      .comparison-inner {
        max-width: 1000px;
        margin: 0 auto;
      }
      .comparison-table {
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 2rem;
        overflow: hidden;
        backdrop-filter: blur(10px);
        margin-top: 3rem;
      }
      .comparison-header {
        display: grid;
        grid-template-columns: 2fr 1.5fr 1.5fr;
        padding: 1.5rem 2.5rem;
        background: rgba(255, 255, 255, 0.06);
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      }
      .comparison-header-cell {
        font-size: 0.6rem;
        font-weight: 700;
        letter-spacing: 0.25em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
      }
      .comparison-header-cell.highlight {
        color: var(--peach-light);
      }
      .comparison-row {
        display: grid;
        grid-template-columns: 2fr 1.5fr 1.5fr;
        padding: 1.5rem 2.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        align-items: center;
        transition: background 0.2s;
      }
      .comparison-row:last-child {
        border-bottom: none;
      }
      .comparison-row:hover {
        background: rgba(255, 255, 255, 0.03);
      }
      .comparison-feature {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.85);
      }
      .comparison-val {
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.4);
      }
      .comparison-val.good {
        color: #a8d89a;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 0.4rem;
      }
      .comparison-val.good::before {
        content: "";
        width: 6px;
        height: 6px;
        background: #a8d89a;
        border-radius: 50%;
        flex-shrink: 0;
      }

      /* ── Contact section ── */
      .contact-section {
        padding: 8rem 2rem;
        max-width: 1400px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 6rem;
        align-items: start;
      }
      @media (max-width: 1024px) {
        .contact-section {
          grid-template-columns: 1fr;
          gap: 3rem;
        }
      }
      .contact-left {
      }
      .contact-benefits {
        margin-top: 3rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
      }
      .contact-benefit {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
      }
      .benefit-check {
        width: 24px;
        height: 24px;
        background: rgba(122, 154, 110, 0.15);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 2px;
      }
      .benefit-text {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.6;
      }
      .benefit-text strong {
        color: var(--text);
      }

      .contact-form-wrap {
        background: white;
        border-radius: 2.5rem;
        padding: 3rem;
        border: 1px solid rgba(122, 154, 110, 0.12);
        box-shadow: 0 40px 80px rgba(45, 74, 38, 0.08);
      }
      .form-group {
        margin-bottom: 1.5rem;
      }
      .form-label {
        display: block;
        font-size: 0.6rem;
        font-weight: 800;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--green-dark);
        margin-bottom: 0.6rem;
      }
      .form-input {
        width: 100%;
        padding: 1rem 1.25rem;
        border: 1.5px solid rgba(122, 154, 110, 0.2);
        border-radius: 1rem;
        font-family: "DM Sans", sans-serif;
        font-size: 0.9rem;
        color: var(--text);
        background: var(--cream);
        outline: none;
        transition: all 0.3s ease;
      }
      .form-input:focus {
        border-color: var(--green);
        background: white;
        box-shadow: 0 0 0 4px rgba(122, 154, 110, 0.08);
      }
      .form-input::placeholder {
        color: rgba(122, 112, 104, 0.5);
      }
      .form-row {
